# AI Service Integration Patterns

Questa regola definisce le convenzioni standard per l'implementazione di servizi di integrazione AI nel progetto Aigens Backend, basate sui pattern identificati in [anthropic.service.js](mdc:services/anthropic.service.js) e [ideogram.service.js](mdc:services/ideogram.service.js).

## Struttura Base del Servizio

### 1. Importazioni e Configurazione

```javascript
// Importazioni standard
const axios = require("axios");
const db = require("../database");
const config = require("../config/config");

// Importazione modelli database
const {
	User,
	Chat,
	Message,
	Attachment,
	Wallet,
	Transaction,
	MessageCost,
	Model,
	Provider,
} = db.sequelize.models;

// Configurazione client API
const client = new ProviderClient({
	apiKey: config.provider.apiKey,
});

// Cache modelli disponibili
let AVAILABLE_MODELS = [];
let lastModelsFetch = null;
const CACHE_DURATION = 3600000; // 1 ora

// Provider ID cache
let PROVIDER_ID = null;
```

### 2. Funzioni Helper Standard

#### Provider ID Management

```javascript
async function getProviderId() {
	if (PROVIDER_ID) return PROVIDER_ID;
	const provider = await Provider.findOne({
		where: { name: "provider-name" },
	});
	if (!provider) throw new Error("Provider non trovato");
	PROVIDER_ID = provider.id;
	return PROVIDER_ID;
}
```

#### Model Availability Check

```javascript
const isModelAvailable = async (modelId) => {
	try {
		const dbModel = await Model.findOne({
			where: {
				api_model_id: modelId,
				id_provider: await getProviderId(),
				is_active: true,
			},
		});
		return !!dbModel;
	} catch (error) {
		console.error("Errore verifica modello:", error);
		return false;
	}
};
```

#### Available Models Fetch

```javascript
const fetchAvailableModels = async () => {
	try {
		const dbModels = await Model.findAll({
			where: {
				id_provider: await getProviderId(),
				is_active: true,
			},
		});

		return dbModels.map((model) => ({
			id: model.model_slug,
			name: model.name,
			description: model.description,
			capabilities: model.capabilities || [],
		}));
	} catch (error) {
		console.error("Errore recupero modelli:", error);
		return [];
	}
};
```

## Pattern di Gestione Costi

### 1. Calcolo Costi Standardizzato

```javascript
const calculateCost = async (
	modelId,
	inputTokens,
	outputTokens = 0,
	includeEstimatedOutput = false
) => {
	// Recupera modello dal database
	const dbModel = await Model.findOne({ where: { api_model_id: modelId } });
	if (!dbModel) throw new Error(`Modello ${modelId} non trovato`);

	// Calcolo base_cost
	const baseCost = calculateBaseCost(inputTokens, outputTokens, dbModel);

	// Calcolo markup
	const markup = calculateMarkup(baseCost, dbModel);
	const totalCost = baseCost + markup;

	return {
		inputTokens,
		outputTokens,
		totalTokens: inputTokens + outputTokens,
		baseCost,
		markup,
		totalCost,
		model: dbModel.model_slug,
		modelId: dbModel.id,
	};
};
```

### 2. Verifica Fondi Utente

```javascript
const checkUserFunds = async (userId, estimatedCost) => {
	const wallet = await Wallet.findOne({ where: { user_id: userId } });
	if (!wallet) throw new Error("Portafoglio utente non trovato");

	const balance = parseFloat(wallet.balance || 0);
	if (balance < estimatedCost) {
		throw new Error(
			`Fondi insufficienti. Costo: ${estimatedCost.toFixed(
				6
			)} USD. Saldo: ${balance.toFixed(6)} USD.`
		);
	}
	return true;
};
```

## Pattern di Gestione Messaggi

### 1. Salvataggio Messaggi

```javascript
const saveMessage = async (messageData) => {
	return await Message.create(messageData);
};

const saveMessageCost = async (costDetails, messageId, chatId, userId) => {
	return await MessageCost.create({
		message_id: messageId,
		chat_id: chatId,
		user_id: userId,
		model_id: costDetails.modelId,
		input_tokens: costDetails.inputTokens,
		output_tokens: costDetails.outputTokens,
		total_tokens: costDetails.totalTokens,
		base_cost: costDetails.baseCost,
		total_markup: costDetails.markup,
		total_cost: costDetails.totalCost,
		model_used: costDetails.model,
	});
};
```

### 2. Gestione Allegati

```javascript
const saveAttachments = async (attachments = [], messageId, chatId, userId) => {
	if (!attachments || attachments.length === 0) return [];

	const savedAttachments = [];
	for (const attachment of attachments) {
		if (typeof attachment === "number") {
			const existingAttachment = await Attachment.findByPk(attachment);
			if (existingAttachment) {
				existingAttachment.message_id = messageId;
				await existingAttachment.save();
				savedAttachments.push(existingAttachment);
			}
		} else {
			const newAttachment = await Attachment.create({
				user_id: userId,
				chat_id: chatId,
				message_id: messageId,
				file_name: attachment.file_name,
				original_name: attachment.original_name,
				file_path: attachment.file_path,
				file_size: attachment.file_size,
				mime_type: attachment.mime_type,
				file_type: attachment.mime_type.startsWith("image/")
					? "image"
					: "other",
			});
			savedAttachments.push(newAttachment);
		}
	}
	return savedAttachments;
};
```

## Pattern di Gestione Wallet

### 1. Aggiornamento Saldo

```javascript
const updateWalletBalance = async (userId, amount) => {
	const wallet = await Wallet.findOne({ where: { user_id: userId } });
	if (!wallet) throw new Error("Portafoglio utente non trovato");

	wallet.balance = parseFloat(wallet.balance) + amount;
	await wallet.save();

	await Transaction.create({
		user_id: userId,
		wallet_id: wallet.id,
		amount: amount,
		currency: wallet.currency,
		type: "usage",
		payment_method: "system",
		status: "completed",
		description: "Utilizzo servizio AI",
	});

	return wallet;
};
```

## Pattern di Gestione Errori

### 1. Error Handling Standardizzato

```javascript
const processRequest = async (requestData) => {
  const { model, prompt, chatId, userId } = requestData;

  // Validazione parametri
  if (!model || !prompt || !chatId || !userId) {
    throw new Error('Parametri mancanti: model, prompt, chatId e userId sono obbligatori');
  }

  // Verifica modello
  const isAvailable = await isModelAvailable(model);
  if (!isAvailable) {
    throw new Error(`Modello non supportato: ${model}`);
  }

  // Verifica utente e chat
  const [user, chat] = await Promise.all([
    User.findByPk(userId),
    Chat.findByPk(chatId)
  ]);

  if (!user) throw new Error(`Utente con ID ${userId} non trovato`);
  if (!chat) throw new Error(`Chat con ID ${chatId} non trovata`);

  let userMessage;
  try {
    // Logica principale del servizio
    userMessage = await saveMessage({...});

    // Chiamata API
    const response = await makeApiCall(requestData);

    // Salvataggio risposta
    const assistantMessage = await saveMessage({...});

    // Aggiornamento costi e wallet
    await saveMessageCost(costDetails, assistantMessage.id, chatId, userId);
    await updateWalletBalance(userId, -costDetails.totalCost);

    return { success: true, message: response, ... };

  } catch (error) {
    // Cleanup in caso di errore
    if (userMessage) {
      await MessageCost.destroy({ where: { message_id: userMessage.id } });
      await Attachment.destroy({ where: { message_id: userMessage.id } });
      await userMessage.destroy();
    }
    throw new Error(`Errore durante la richiesta: ${error.message}`);
  }
};
```

