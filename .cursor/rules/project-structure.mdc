```
aigens-backend/
├── server.js                    # Entry point principale dell'applicazione
├── package.json                 # Dipendenze e configurazione npm
├── jest.config.js              # Configurazione Jest per i test
├── .sequelizerc                # Configurazione Sequelize ORM
└── README.md                   # Documentazione principale
```

