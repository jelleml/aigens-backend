{
  "name": "aigens-backend",
  "version": "1.0.0",
  "description": "Backend per la piattaforma AIGens",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev-no-openssl": "NODE_OPTIONS='--openssl-legacy-provider' nodemon server.js",
    "test": "jest",
    "test:detect": "jest --detectOpenHandles",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:performance": "jest --selectProjects performance",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "test:ideogram": "node tests/ideogram/run-all-tests.js",
    "test:ideogram:quick": "node tests/ideogram/diagnostic-ideogram.js",
    "test:services": "for test in tests/services/*.js; do echo \"=== Running $(basename $test) ===\"; node \"$test\"; done",
    "test:api": "for test in tests/api/*.js; do echo \"=== Running $(basename $test) ===\"; node \"$test\"; done",
    "test:utils": "for test in tests/utils/*.js; do echo \"=== Running $(basename $test) ===\"; node \"$test\"; done",
    "setup:test-user": "node tests/setup/create-test-user.js",
    "setup:recreate-test-user": "node tests/setup/recreate-test-user.js",
    "seed": "npx sequelize-cli db:seed:all",
    "migration:create": "npx sequelize-cli migration:create",
    "migration:up": "npx sequelize-cli db:migrate",
    "migration:down": "npx sequelize-cli db:migrate:undo",
    "migration:verify": "node scripts/verify-migration-state.js",
    "migration:cleanup": "node scripts/cleanup-duplicate-indexes.js",
    "migration:cleanup:dry-run": "node scripts/cleanup-duplicate-indexes.js --dry-run",
    "migration:test": "node scripts/test-migration-helpers.js",
    "cleanup-indexes": "node scripts/remove-duplicated-indexes-from-db.js",
    "setup-models": "node scripts/setup-init/setup-models-modern.js",
    "setup-models-modern": "node scripts/setup-init/setup-models-modern.js",
    "setup-models-clean": "node scripts/setup-init/setup-models-clean.js",
    "setup-models-legacy": "node scripts/setup-init/setup-models-complete.js",
    "init-providers": "node scripts/setup-init/init-provider-subscriptions.js",
    "truncate-models": "node scripts/setup-init/truncate-models-and-providers.js",
    "verify-setup": "node scripts/verify-setup.js",
    "debug-setup": "node scripts/setup-init/debug-setup.js",
    "update-model-stats-aa-and-relations": "node scripts/setup-init/update-model-stats-aa-and-relations.js",
    "verify-model-stats": "node scripts/verify-model-stats.js",
    "verify-model-stats-simple": "node scripts/setup-init/verify-model-stats-simple.js",
    "lint": "eslint .",
    "model-mgmt": "node services/model-management/cli/index.js",
    "model-mgmt:sync": "npm run model-mgmt sync",
    "model-mgmt:health": "npm run model-mgmt health",
    "model-mgmt:interactive": "npm run model-mgmt interactive",
    "model-mgmt:status": "npm run model-mgmt status",
    "model-mgmt:metrics": "npm run model-mgmt metrics",
    "model-mgmt:providers": "npm run model-mgmt providers --list --status",
    "model-mgmt:models": "npm run model-mgmt models --list",
    "model-mgmt:logs": "npm run model-mgmt logs",
    "model-mgmt:config": "npm run model-mgmt config --show",
    "model-mgmt:maintenance": "npm run model-mgmt maintenance",
    "sync:all": "npm run model-mgmt sync",
    "sync:openai": "npm run model-mgmt sync --provider openai",
    "sync:anthropic": "npm run model-mgmt sync --provider anthropic",
    "sync:together": "npm run model-mgmt sync --provider together",
    "sync:openrouter": "npm run model-mgmt sync --provider openrouter",
    "sync:deepseek": "npm run model-mgmt sync --provider deepseek",
    "sync:ideogram": "npm run model-mgmt sync --provider ideogram",
    "model-mgmt:scheduler:start": "node scripts/model-management/unified-sync.js --schedule",
    "model-mgmt:scheduler:stop": "node scripts/model-management/unified-sync.js --stop-schedule",
    "model-mgmt:monitor": "node services/model-management/cli/index.js health --watch --interval 60",
    "update-model-status-pricing-presence": "node scripts/setup-init/update-model-active-status.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.27",
    "@ai-sdk/openai": "^2.0.49",
    "@anthropic-ai/sdk": "^0.39.0",
    "@getalby/sdk": "^5.1.1",
    "@google-cloud/storage": "^7.16.0",
    "@google/genai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.5",
    "ai": "^5.0.68",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.8.1",
    "bcryptjs": "^2.4.3",
    "boxen": "^7.1.1",
    "btcpay-greenfield-node-client": "^1.7.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "columnify": "^1.6.0",
    "commander": "^12.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^4.3.2",
    "crypto-random-string": "^5.0.0",
    "csurf": "^1.10.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "hbs": "^4.2.0",
    "helmet": "^7.2.0",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.9.1",
    "mjml": "^4.15.3",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.0",
    "openai": "^4.87.3",
    "ora": "^5.4.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "passport-oauth2": "^1.8.0",
    "passwordless": "^1.1.3",
    "passwordless-sequelize": "^0.2.0",
    "pdf-parse": "^1.1.1",
    "pptx-text-parser": "^1.1.1",
    "qrcode": "^1.5.4",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.3",
    "strip-ansi": "^7.1.0",
    "stripe": "^18.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "textract": "^2.5.0",
    "ua-parser-js": "^1.0.37",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
