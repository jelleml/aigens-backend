# Model Management System Environment Configuration
# Copy this file to .env and customize the values as needed

# =============================================================================
# EXECUTION SETTINGS
# =============================================================================

# Execution strategy: sequential, parallel, mixed
MODEL_MGMT_STRATEGY=mixed

# Maximum concurrent provider operations
MODEL_MGMT_CONCURRENCY=3

# Batch size for processing models
MODEL_MGMT_BATCH_SIZE=50

# Enable dry-run mode (test without making changes)
MODEL_MGMT_DRY_RUN=false

# Auto-confirm operations without prompting
MODEL_MGMT_AUTO_CONFIRM=false

# =============================================================================
# TIMEOUT SETTINGS (in milliseconds)
# =============================================================================

# Timeout for individual provider operations (5 minutes)
MODEL_MGMT_PROVIDER_TIMEOUT=300000

# Total execution timeout (30 minutes)
MODEL_MGMT_TOTAL_TIMEOUT=1800000

# Health check timeout (30 seconds)
MODEL_MGMT_HEALTH_TIMEOUT=30000

# Database transaction timeout (2 minutes)
MODEL_MGMT_TRANSACTION_TIMEOUT=120000

# API request timeout (30 seconds)
MODEL_MGMT_API_TIMEOUT=30000

# =============================================================================
# RETRY SETTINGS
# =============================================================================

# Maximum retry attempts
MODEL_MGMT_MAX_RETRIES=3

# Initial retry delay (30 seconds)
MODEL_MGMT_RETRY_DELAY=30000

# Backoff multiplier for exponential backoff
MODEL_MGMT_BACKOFF_MULTIPLIER=2

# Maximum retry delay (5 minutes)
MODEL_MGMT_MAX_RETRY_DELAY=300000

# Enable jitter in retry delays
MODEL_MGMT_RETRY_JITTER=true

# =============================================================================
# CIRCUIT BREAKER SETTINGS
# =============================================================================

# Number of consecutive failures before opening circuit breaker
MODEL_MGMT_FAILURE_THRESHOLD=5

# Recovery timeout for circuit breaker (1 minute)
MODEL_MGMT_RECOVERY_TIMEOUT=60000

# Number of requests to allow in half-open state
MODEL_MGMT_HALF_OPEN_REQUESTS=3

# Enable circuit breaker functionality
MODEL_MGMT_CIRCUIT_BREAKER=true

# =============================================================================
# HEALTH CHECK SETTINGS
# =============================================================================

# Enable health checks
MODEL_MGMT_HEALTH_CHECK=true

# Skip unhealthy providers during sync
MODEL_MGMT_SKIP_UNHEALTHY=true

# Health score threshold (0-100)
MODEL_MGMT_HEALTH_THRESHOLD=70.0

# Error rate threshold percentage
MODEL_MGMT_ERROR_RATE_THRESHOLD=10.0

# Health check interval (5 minutes)
MODEL_MGMT_HEALTH_INTERVAL=300000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: debug, info, warn, error
MODEL_MGMT_LOG_LEVEL=info

# Log directory path
MODEL_MGMT_LOG_DIR=./logs/model-management

# Log filename
MODEL_MGMT_LOG_FILE=model-management.log

# Maximum log file size
MODEL_MGMT_LOG_MAX_SIZE=50MB

# Maximum number of log files to keep
MODEL_MGMT_LOG_MAX_FILES=10

# Date pattern for log rotation
MODEL_MGMT_LOG_DATE_PATTERN=YYYY-MM-DD

# Enable console logging
MODEL_MGMT_LOG_CONSOLE=true

# Enable file logging
MODEL_MGMT_LOG_FILE_ENABLED=true

# Enable log rotation
MODEL_MGMT_LOG_ROTATION=true

# Use structured logging (JSON format)
MODEL_MGMT_LOG_STRUCTURED=true

# =============================================================================
# METRICS COLLECTION
# =============================================================================

# Enable metrics collection
MODEL_MGMT_METRICS=true

# Metrics collection interval (1 minute)
MODEL_MGMT_METRICS_INTERVAL=60000

# Metrics retention period (7 days)
MODEL_MGMT_METRICS_RETENTION=604800000

# Metrics export interval (5 minutes)
MODEL_MGMT_METRICS_EXPORT_INTERVAL=300000

# Metrics aggregation window (5 minutes)
MODEL_MGMT_METRICS_WINDOW=300000

# =============================================================================
# SYNCHRONIZATION SETTINGS
# =============================================================================

# Cron schedule for full sync (Weekly on Sunday at 2 AM)
MODEL_MGMT_FULL_SYNC_CRON="0 2 * * 0"

# Cron schedule for incremental sync (Every 6 hours)
MODEL_MGMT_INCREMENTAL_SYNC_CRON="0 */6 * * *"

# Cron schedule for health checks (Every 15 minutes)
MODEL_MGMT_HEALTH_CRON="*/15 * * * *"

# Cron schedule for cleanup (Daily at 3 AM)
MODEL_MGMT_CLEANUP_CRON="0 3 * * *"

# Cooldown period between syncs (1 hour)
MODEL_MGMT_COOLDOWN=3600000

# Enable batch processing
MODEL_MGMT_BATCH_PROCESSING=true

# Validate data before sync
MODEL_MGMT_VALIDATE_SYNC=true

# Skip sync on errors
MODEL_MGMT_SKIP_ON_ERRORS=false

# =============================================================================
# OPENAI PROVIDER SETTINGS
# =============================================================================

MODEL_MGMT_OPENAI_PRIORITY=1
MODEL_MGMT_OPENAI_TIMEOUT=120000
MODEL_MGMT_OPENAI_SYNC_CRON="0 */4 * * *"
MODEL_MGMT_OPENAI_HEALTH_CRON="*/10 * * * *"
MODEL_MGMT_OPENAI_ENABLED=true
MODEL_MGMT_OPENAI_RATE_LIMIT=100
MODEL_MGMT_OPENAI_RATE_WINDOW=60000

# OpenAI maintenance window
MODEL_MGMT_OPENAI_MAINTENANCE=false
MODEL_MGMT_OPENAI_MAINTENANCE_START=2
MODEL_MGMT_OPENAI_MAINTENANCE_END=4

# =============================================================================
# ANTHROPIC PROVIDER SETTINGS
# =============================================================================

MODEL_MGMT_ANTHROPIC_PRIORITY=2
MODEL_MGMT_ANTHROPIC_TIMEOUT=180000
MODEL_MGMT_ANTHROPIC_SYNC_CRON="0 */6 * * *"
MODEL_MGMT_ANTHROPIC_HEALTH_CRON="*/15 * * * *"
MODEL_MGMT_ANTHROPIC_ENABLED=true
MODEL_MGMT_ANTHROPIC_RATE_LIMIT=50
MODEL_MGMT_ANTHROPIC_RATE_WINDOW=60000

# =============================================================================
# DEEPSEEK PROVIDER SETTINGS
# =============================================================================

MODEL_MGMT_DEEPSEEK_PRIORITY=4
MODEL_MGMT_DEEPSEEK_TIMEOUT=150000
MODEL_MGMT_DEEPSEEK_SYNC_CRON="0 */8 * * *"
MODEL_MGMT_DEEPSEEK_HEALTH_CRON="*/20 * * * *"
MODEL_MGMT_DEEPSEEK_ENABLED=true
MODEL_MGMT_DEEPSEEK_RATE_LIMIT=30
MODEL_MGMT_DEEPSEEK_RATE_WINDOW=60000

# =============================================================================
# IDEOGRAM PROVIDER SETTINGS
# =============================================================================

MODEL_MGMT_IDEOGRAM_PRIORITY=5
MODEL_MGMT_IDEOGRAM_TIMEOUT=120000
MODEL_MGMT_IDEOGRAM_SYNC_CRON="0 */12 * * *"
MODEL_MGMT_IDEOGRAM_HEALTH_CRON="*/30 * * * *"
MODEL_MGMT_IDEOGRAM_ENABLED=true
MODEL_MGMT_IDEOGRAM_RATE_LIMIT=20
MODEL_MGMT_IDEOGRAM_RATE_WINDOW=60000

# =============================================================================
# TOGETHER PROVIDER SETTINGS
# =============================================================================

MODEL_MGMT_TOGETHER_PRIORITY=6
MODEL_MGMT_TOGETHER_TIMEOUT=180000
MODEL_MGMT_TOGETHER_SYNC_CRON="0 */8 * * *"
MODEL_MGMT_TOGETHER_HEALTH_CRON="*/20 * * * *"
MODEL_MGMT_TOGETHER_ENABLED=true
MODEL_MGMT_TOGETHER_RATE_LIMIT=40
MODEL_MGMT_TOGETHER_RATE_WINDOW=60000

# =============================================================================
# OPENROUTER PROVIDER SETTINGS
# =============================================================================

MODEL_MGMT_OPENROUTER_PRIORITY=3
MODEL_MGMT_OPENROUTER_TIMEOUT=300000
MODEL_MGMT_OPENROUTER_SYNC_CRON="0 */4 * * *"
MODEL_MGMT_OPENROUTER_HEALTH_CRON="*/15 * * * *"
MODEL_MGMT_OPENROUTER_ENABLED=true
MODEL_MGMT_OPENROUTER_RATE_LIMIT=200
MODEL_MGMT_OPENROUTER_RATE_WINDOW=60000

# =============================================================================
# CLI CONFIGURATION
# =============================================================================

# CLI theme: default, minimal, verbose
MODEL_MGMT_CLI_THEME=default

# Enable colored output
MODEL_MGMT_CLI_COLORS=true

# Show progress bars
MODEL_MGMT_CLI_PROGRESS=true

# Show timestamps in output
MODEL_MGMT_CLI_TIMESTAMPS=false

# Show confirmation prompts
MODEL_MGMT_CLI_CONFIRM=true

# Output format: table, json, minimal
MODEL_MGMT_CLI_FORMAT=table

# Page size for paginated output
MODEL_MGMT_CLI_PAGE_SIZE=20

# CLI configuration file path
MODEL_MGMT_CLI_CONFIG=~/.model-management/config.json

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Base URL for API requests
MODEL_MGMT_API_URL=http://localhost:3000

# API request timeout
MODEL_MGMT_API_TIMEOUT=30000

# API request retries
MODEL_MGMT_API_RETRIES=3

# API rate limiting
MODEL_MGMT_API_RATE_LIMIT=true
MODEL_MGMT_API_RATE_WINDOW=60000
MODEL_MGMT_API_MAX_REQUESTS=100

# =============================================================================
# ALERTING CONFIGURATION
# =============================================================================

# Enable alerting system
MODEL_MGMT_ALERTING=false

# Email alerts
MODEL_MGMT_EMAIL_ALERTS=false
MODEL_MGMT_SMTP_HOST=smtp.gmail.com
MODEL_MGMT_SMTP_PORT=587
MODEL_MGMT_SMTP_SECURE=false
MODEL_MGMT_SMTP_USER=your-email@gmail.com
MODEL_MGMT_SMTP_PASS=your-app-password
MODEL_MGMT_EMAIL_FROM=model-management@aigens.com
MODEL_MGMT_EMAIL_TO=admin@aigens.com,ops@aigens.com

# Slack alerts
MODEL_MGMT_SLACK_ALERTS=false
MODEL_MGMT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
MODEL_MGMT_SLACK_CHANNEL=#model-management
MODEL_MGMT_SLACK_USERNAME=Model Management Bot

# Webhook alerts
MODEL_MGMT_WEBHOOK_ALERTS=false
MODEL_MGMT_WEBHOOK_URL=https://your-monitoring-system.com/webhooks/alerts
MODEL_MGMT_WEBHOOK_HEADERS={"Authorization":"Bearer your-token"}

# Alert thresholds
MODEL_MGMT_ALERT_HEALTH_THRESHOLD=70.0
MODEL_MGMT_ALERT_ERROR_THRESHOLD=10.0
MODEL_MGMT_ALERT_RESPONSE_THRESHOLD=30000
MODEL_MGMT_ALERT_FAILURE_THRESHOLD=3
MODEL_MGMT_ALERT_MEMORY_THRESHOLD=85.0
MODEL_MGMT_ALERT_DISK_THRESHOLD=90.0

# Alert cooldown periods (in milliseconds)
MODEL_MGMT_EMAIL_COOLDOWN=3600000
MODEL_MGMT_SLACK_COOLDOWN=1800000
MODEL_MGMT_WEBHOOK_COOLDOWN=900000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database batch size for bulk operations
MODEL_MGMT_DB_BATCH_SIZE=100

# Database transaction timeout
MODEL_MGMT_DB_TRANSACTION_TIMEOUT=120000

# Database connection pool settings
MODEL_MGMT_DB_POOL_MIN=2
MODEL_MGMT_DB_POOL_MAX=10
MODEL_MGMT_DB_ACQUIRE_TIMEOUT=60000
MODEL_MGMT_DB_IDLE_TIMEOUT=300000

# Data retention periods (in milliseconds)
MODEL_MGMT_SYNC_LOGS_RETENTION=2592000000  # 30 days
MODEL_MGMT_HEALTH_RETENTION=604800000      # 7 days
MODEL_MGMT_METRICS_RETENTION=2592000000    # 30 days

# Database cleanup
MODEL_MGMT_DB_CLEANUP=true
MODEL_MGMT_DB_CLEANUP_CRON="0 4 * * *"
MODEL_MGMT_DB_CLEANUP_BATCH=1000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# API key rotation
MODEL_MGMT_API_KEY_ROTATION=false
MODEL_MGMT_API_KEY_CHECK_INTERVAL=86400000  # Daily
MODEL_MGMT_API_KEY_WARNING=604800000        # 7 days

# Encryption and security
MODEL_MGMT_ENCRYPTION=false
MODEL_MGMT_AUDIT_LOGGING=true
MODEL_MGMT_ACCESS_CONTROL=false
MODEL_MGMT_ROLES=admin,operator,readonly

# =============================================================================
# DEVELOPMENT AND TESTING
# =============================================================================

# Mock providers for testing
MODEL_MGMT_MOCK_PROVIDERS=false

# Verbose logging for development
MODEL_MGMT_VERBOSE=false

# Skip validation for testing
MODEL_MGMT_SKIP_VALIDATION=false

# Test database name
MODEL_MGMT_TEST_DB=model_management_test